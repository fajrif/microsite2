// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


model Admin {
  id            String   @id @default(uuid())
  email         String   @unique
  full_name     String
  phone         String?
  password_hash String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("admins")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]

  @@map("categories")
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
}

enum CareerStatus {
  DRAFT
  PUBLISHED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
}

model Article {
  id                String        @id @default(uuid())
  title             String        @unique
  slug              String        @unique
  short_description String?
  content           String?       @db.Text
  image             String?
  gallery_images    String[]      // Array of gallery image URLs
  category_id       String
  published_date    DateTime?
  status            ArticleStatus @default(DRAFT)
  meta_title        String?
  meta_description  String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  category Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@index([slug])
  @@map("articles")
}

model Career {
  id                String         @id @default(uuid())
  title             String         @unique
  slug              String         @unique
  department        String
  location          String
  employment_type   EmploymentType @default(FULL_TIME)
  short_description String?
  content           String?        @db.Text
  requirements      String?        @db.Text
  benefits          String?        @db.Text
  salary_range      String?
  published_date    DateTime?
  status            CareerStatus   @default(DRAFT)
  meta_title        String?
  meta_description  String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([slug])
  @@map("careers")
}

model Inquiry {
  id        String   @id @default(uuid())
  name      String
  email     String
  company   String?
  message   String   @db.Text
  ip        String?
  createdAt DateTime @default(now())

  @@map("inquiries")
}

model User {
  id            String   @id @default(uuid())
  username      String   @unique
  full_name     String
  phone         String?
  company       String?
  password_hash String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model AdProduct {
  id          String    @id @default(uuid()) @db.Uuid
  orderNo     Int       @default(0)
  name        String    @unique
  slug        String    @unique
  image       String
  description String?   @db.Text
  tagline     String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  features    Feature[]
  surveys     Survey[]

  @@index([slug])
  @@map("ad_products")
}

model Feature {
  id            String    @id @default(uuid()) @db.Uuid
  orderNo       Int       @default(0)
  name          String
  image         String
  video_link    String?
  audio_link    String?
  ad_product_id String    @db.Uuid
  caption       String?
  description   String?   @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  ad_product AdProduct @relation(fields: [ad_product_id], references: [id], onDelete: Cascade)

  @@map("features")
}

model Survey {
  id            String   @id @default(uuid()) @db.Uuid
  ad_product_id String   @db.Uuid
  rating        Int
  ip            String
  createdAt     DateTime @default(now())

  ad_product AdProduct @relation(fields: [ad_product_id], references: [id], onDelete: Cascade)

  @@index([ad_product_id])
  @@index([ip, ad_product_id])
  @@map("surveys")
}
